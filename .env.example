# Better Auth
# NUXT_BETTER_AUTH_SECRET overrides runtimeConfig.betterAuthSecret at runtime.
# Required in production - generate a long random string, e.g.:
#   openssl rand -base64 32
NUXT_BETTER_AUTH_SECRET=change-me-to-a-long-random-string

# NUXT_PUBLIC_BETTER_AUTH_URL overrides runtimeConfig.public.betterAuthUrl.
NUXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Database (SQLite file path)
# NUXT_DB_FILE_PATH overrides runtimeConfig.dbFilePath. The containing
# directory is created automatically if it does not exist yet.
NUXT_DB_FILE_PATH=./data/app.db
